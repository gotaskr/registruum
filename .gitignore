# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage
/playwright-report/
/test-results/
/blob-report/

# next.js
/.next/
/out/
/.next-*/

# production
/build
/dist/
/dist.zip

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!/.env.example

# supabase local state
/supabase/.temp
/supabase/.branches

# vercel
.vercel

# local scaffolds / scratch folders
/registruum-bootstrap/
/scratch/
registruum-backup-*.zip

# Cursor / CLI installed agent skills (large; regenerate with npx skills add)
/.agents/
/skills-lock.json

# typescript
*.tsbuildinfo
next-env.d.ts

# Billing / Stripe / subscription (local-only; not pushed). Copy your own versions back into these paths after clone.
# `stripe` stays in devDependencies so Next/typecheck still resolve when these files exist locally.
/scripts/run-stripe.ps1
/src/app/api/billing/
/src/lib/stripe/
/src/app/(app)/settings/plans/
/src/features/settings/api/storage.ts
/src/features/settings/api/subscription.ts
/src/features/settings/lib/plan-card-formatters.ts
/src/features/settings/lib/subscription-enforcement.ts
/src/features/settings/lib/subscription-plans.ts
/src/features/settings/types/upgrade-prompt.ts
/src/features/settings/ui/billing-plans-page-content.tsx
/src/features/settings/ui/storage-settings-section.tsx
/src/features/settings/ui/subscription-settings-section.tsx
/src/features/settings/ui/upgrade-required-modal.tsx
/supabase/migrations/*profile*billing*.sql
