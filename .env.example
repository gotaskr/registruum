SUPABASE_SERVICE_ROLE_KEY=replace-with-hosted-service-role-key

# Optional: set to false when Supabase is unreachable to avoid browser realtime connection errors in dev.
# NEXT_PUBLIC_REALTIME_ROUTE_REFRESH=false

# Google Maps JavaScript API + Places (optional; Create Space address autocomplete).
# Hosted (Vercel etc.): set NEXT_PUBLIC_GOOGLE_MAPS_API_KEY in Production env and redeploy — it is inlined at build time.
# Key: enable Maps JavaScript API + Places API (legacy); HTTP referrer allowlist must include your live origin(s), e.g.
#   https://www.yourdomain.com/*  https://yourdomain.com/*
# Optional: send only the origin as referrer (only if your Cloud key restriction includes a domain-without-path rule).
# NEXT_PUBLIC_GOOGLE_MAPS_AUTH_REFERRER_ORIGIN=true
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=

# Stripe (billing): set when you go live; required for checkout, portal, and webhooks.
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=
# Each value must be a recurring subscription Price id (price_…), copied from Dashboard → Product → Pricing.
# Do not use the Product id (prod_…); Stripe Checkout line_items require price_….
# STRIPE_PRICE_ID_BASIC=
# STRIPE_PRICE_ID_PRO_TEAM=
# STRIPE_PRICE_ID_BUSINESS=
# STRIPE_PRICE_ID_ENTERPRISE=
# Optional: manual Tax Rate ids (Dashboard → Products → Tax rates), comma-separated, max 5.
# When set, Checkout collects a full billing address so province-scoped rates (e.g. Ontario) can apply.
# STRIPE_MANUAL_TAX_RATE_IDS=txr_xxxx
# Set each recurring Price’s Tax behavior in Stripe (Exclusive/Inclusive) to match the rate — not "Unspecified" or tax may not show.
# Until Stripe is live on a hosted build, hide billing UI and block checkout/portal/plans (local dev: omit this).
# NEXT_PUBLIC_BILLING_DISABLED=true
